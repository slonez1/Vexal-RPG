
# Rename to .env and fill values for local dev (do NOT commit real secrets)
OPENAI_API_KEY=sk-...
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcloud-key.json
GCS_BUCKET=your-audio-cache-bucket
USE_GCS_CACHE=true
AUDIO_CACHE_DIR=./audio_cache
OPENAI_CHAT_MODEL=gpt-4o-mini
# OAuth client for Google Drive (optional)
GOOGLE_DRIVE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=http://localhost:8000/oauth2callback
